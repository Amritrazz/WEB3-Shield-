{
  "manifest_version": 3,
  "name": "Web3 Shield",
  "version": "1.0.0",
  "description": "Real-time Web3 phishing & scam protection",
  "permissions": [
    "storage", "tabs", "scripting",
    "notifications", "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": [
      "content/wallet_monitor.js",
      "content/page_scanner.js"
    ],
    "run_at": "document_start"
  }],
 "action": {
  "default_popup": "popup/popup.html"
 }
}